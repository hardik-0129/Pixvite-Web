# Pixvite-Web — copy to .env on the VPS. Never commit .env.

# ─── Domains (production) ─────────────────────────────────────────────────────
# Site:    https://invitesmagic.com
# Admin:   https://dashboard.invitesmagic.com
# Render:  https://render.invitesmagic.com

MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/Pixvite_Prod
JWT_SECRET=CHANGE_ME_64_CHAR_HEX_SECRET

RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
RAZORPAY_WEBHOOK_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
SMTP_FROM="Invites Magic your@email.com"

NEXT_PUBLIC_BACKEND_PREFIX=https://invitesmagic.com
TEMPLATE_ASSETS_UPSTREAM=https://dashboard.invitesmagic.com

NEXT_PUBLIC_LOTTIE_RENDER_SERVER_URL=https://render.invitesmagic.com
RENDER_SECRET=CHANGE_ME_RENDER_SECRET
NEXT_PUBLIC_LOTTIE_RENDER_SECRET=CHANGE_ME_RENDER_SECRET
NEXT_PUBLIC_LOTTIE_RENDER_ENGINE=remotion

ALLOW_FETCH_HOSTS=localhost,127.0.0.1,invitesmagic.com,www.invitesmagic.com,dashboard.invitesmagic.com,render.invitesmagic.com

# Optional — Google Sign-In (https://console.cloud.google.com)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

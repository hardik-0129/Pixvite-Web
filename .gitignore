# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (any depth — e.g. render-server/node_modules)
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# User uploads & render output (never commit — survives git pull on VPS)
/public/uploads/*
!/public/uploads/.gitkeep
!/public/uploads/images/
/public/uploads/images/*
!/public/uploads/images/.gitkeep
!/public/uploads/audio/
/public/uploads/audio/*
!/public/uploads/audio/.gitkeep
/public/videos/*
!/public/videos/.gitkeep
/render-server/order-renders/*
!/render-server/order-renders/.gitkeep
